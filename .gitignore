# ---------------------------------------------------------------------------
# .gitignore — vscode-chess (Node + TypeScript + VS Code extension)
# Defense-in-depth: secrets/keys are denied here at the git layer AND by the
# .publish allowlist. Build output and local cruft never get committed.
# ---------------------------------------------------------------------------

# --- Secrets & credentials (SecOps: never commit) --------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.pkcs12
*.p12
*.pfx
*.cer
*.crt
*.der
id_rsa
id_rsa.*
id_dsa
id_ecdsa
id_ed25519
*.keystore
*.jks
*.secret
*.secret.*
secrets.json
credentials.json
.npmrc
.pypirc
.netrc

# --- Dependencies ----------------------------------------------------------
node_modules/
jspm_packages/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# --- Build output / bundles ------------------------------------------------
dist/
out/
build/
*.vsix
*.tsbuildinfo

# --- Test / coverage / VS Code extension test host -------------------------
.vscode-test/
.vscode-test-web/
coverage/
.nyc_output/
*.lcov

# --- Logs & debug ----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.*.json

# --- Caches & temp ---------------------------------------------------------
.cache/
.eslintcache
.parcel-cache/
.npm/
*.tmp
*.temp
tmp/
temp/
*.pid
*.seed
*.pid.lock

# --- Editor / IDE ----------------------------------------------------------
# Keep shared VS Code workspace config (launch.json is tracked); ignore the rest.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.idea/
*.iml
*.swp
*.swo
*~
*.bak
*.orig
*.rej

# --- OS cruft --------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
